# =============================================================================
# secrets.toml — Configuração de URL permanente do Google Sheets
#
# ATENÇÃO: este arquivo é um EXEMPLO. Nunca suba o secrets.toml real
# para o GitHub — ele deve ser configurado direto no painel do Streamlit Cloud.
#
# Como usar:
#   1. Acesse seu app em share.streamlit.io
#   2. Clique em "⋮" → "Settings" → aba "Secrets"
#   3. Cole o conteúdo abaixo com a URL real da sua planilha
#   4. Clique em "Save" — o app reinicia com a URL fixada
#
# Com isso, o campo de URL já aparece preenchido para todos os usuários
# e o dashboard sincroniza automaticamente a cada 5 minutos.
# =============================================================================

SHEETS_URL = "https://docs.google.com/spreadsheets/d/SEU_ID_AQUI/edit"
