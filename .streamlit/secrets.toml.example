# =============================================================================
# secrets.toml — Configurações protegidas do Dashboard MAZ
#
# ATENÇÃO: este arquivo é um EXEMPLO.
# Nunca suba o secrets.toml real para o GitHub — configure direto no
# painel do Streamlit Cloud em: App → "⋮" → Settings → Secrets
#
# Cole as linhas abaixo com os valores reais e clique em "Save".
# O app reinicia automaticamente com as configurações aplicadas.
# =============================================================================

# --- Credenciais de administrador ---
# Protege os campos de Link e Aba contra alteração por usuários comuns.
ADMIN_LOGIN = "jhfp@mazt&p"
ADMIN_SENHA = "mazt&p@2026"

# --- 2FA do Owner (opcional, mas recomendado) ---
# Deixe de fora até você mesmo gerar o segredo pela tela de Configurações
# (seção "Autenticação de dois fatores") — ela mostra o QR Code e o valor
# exato pra colar aqui. Depois de salvo, o login do Owner passa a exigir
# o código do app autenticador além da senha.
# ADMIN_TOTP_SECRET = "..."

# --- "Entrar com Google" (obrigatório para Admin/Viewer/Requisitante) ---
# Restringe o login da equipe a contas @idg.org.br de verdade — o Google
# quem confirma a identidade, o app só lê o e-mail já verificado.
#
# Como obter (uma vez, no MESMO projeto do Google Cloud já usado pela
# Service Account, ou em outro — tanto faz):
#   1. Google Cloud Console → APIs e Serviços → Tela de consentimento OAuth
#      → tipo de usuário "Interno" (exige Workspace) OU "Externo" com o
#      app em modo "Testing"/"Produção" restrito ao seu domínio.
#   2. APIs e Serviços → Credenciais → Criar credenciais → ID do cliente OAuth
#      → tipo "Aplicativo da Web".
#   3. Em "URIs de redirecionamento autorizados", adicione a URL do seu app
#      no Streamlit Cloud + "/oauth2callback", ex:
#        https://seu-app.streamlit.app/oauth2callback
#   4. Copiar o Client ID e o Client Secret gerados.
#   5. cookie_secret é só uma string aleatória forte (ex: gerada com
#      `python -c "import secrets; print(secrets.token_hex(32))"`), usada
#      pelo Streamlit pra assinar o cookie de sessão — não é do Google.
[auth]
redirect_uri    = "https://seu-app.streamlit.app/oauth2callback"
cookie_secret   = "uma-string-aleatoria-bem-grande-aqui"
client_id       = "SEU_CLIENT_ID.apps.googleusercontent.com"
client_secret   = "SEU_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
client_kwargs   = { prompt = "select_account", hd = "idg.org.br" }

# --- Fonte de dados padrão ---
# A URL e o nome da aba ficam fixados para todos os usuários.
# O admin pode alterá-los pela interface sem precisar editar este arquivo.
SHEETS_URL = "https://docs.google.com/spreadsheets/d/SEU_ID_AQUI/edit"
SHEETS_ABA = "Nome Exato Da Aba"

# --- Service Account do Google (habilita os formulários de lançamento) ---
# Sem isso, o dashboard continua funcionando normalmente, só em modo
# somente-leitura — os formulários de "Novo Lançamento" ficam ocultos.
#
# Como obter:
#   1. Google Cloud Console → criar projeto (gratuito) → ativar "Google Sheets API"
#   2. Criar uma Service Account nesse projeto → gerar chave JSON
#   3. Compartilhar a planilha (Editor) com o e-mail da Service Account
#      (algo como nome@seu-projeto.iam.gserviceaccount.com)
#   4. Colar os campos do arquivo JSON baixado exatamente como abaixo
#
# [gcp_service_account]
# type                        = "service_account"
# project_id                  = "seu-projeto-id"
# private_key_id              = "..."
# private_key                 = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email                = "nome@seu-projeto.iam.gserviceaccount.com"
# client_id                   = "..."
# auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
# token_uri                   = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url        = "..."
